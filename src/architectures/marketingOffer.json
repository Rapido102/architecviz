      "type": "db",
      "layer": "Data",
      "technology": "PostgreSQL",
      "url": "${cloud_postgre_database_marketing_offer_url}",
      "port": 5432,
      "consumed_via": "Spring JDBC (NamedParameterJdbcTemplate / JdbcTemplate)",
      "tables": [
        {
          "name": "t38_offre",
          "purpose": "Référentiel des offres marketing et de leurs périodes de validité"
        },
        {
          "name": "t38_parametrage_offre",
          "purpose": "Paramétrages des offres par sous-produit et primes associées"
        },
        {
          "name": "t38_produit",
          "purpose": "Catalogue des produits Fortuneo éligibles aux offres"
        },
        {
          "name": "t38_sous_produit",
          "purpose": "Catalogue des sous-produits rattachés aux produits"
        },
        {
          "name": "t38_condition_encours",
          "purpose": "Conditions d'encours applicables aux offres"
        },
        {
          "name": "t38_condition_palier",
          "purpose": "Conditions à paliers rattachées aux paramétrages d'offre"
        },
        {
          "name": "t38_condition_taux_uc",
          "purpose": "Conditions de taux d'unités de compte"
        },
        {
          "name": "t38_condition_versement_initial",
          "purpose": "Conditions de versement initial"

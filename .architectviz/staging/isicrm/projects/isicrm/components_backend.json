[
  {
    "id": "isicrm_backend",
    "label": "ISiCRM Backend",
    "type": "backend",
    "layer": "Backend",
    "technology": "Java 17 + Spring MVC 5.3.5 + OpenFeign 13.2.1 + Apache Thrift + WAR/Tomcat 9",
    "url": "${ISICRM_URL}",
    "port": 8080,
    "authentication": {
      "type": "Sécurité portée majoritairement par l’infrastructure d’exposition (API interne / Tomcat), sans Spring Security détecté dans le code scanné",
      "provider": "Contrôles d’accès applicatifs externes à confirmer côté plateforme d’hébergement ; 401/403 documentés dans les Swagger ISI-CRM",
      "token_format": "Aucun token entrant standardisé détecté dans le code serveur scanné ; usage de query params métier (codeAcces) et ponctuellement du header x-arkea-numeropersonne",
      "token_expiry": "Gérée hors application par l’infrastructure/gateway ; non portée par le code scanné",
      "roles_permissions": "Le code ne montre pas de règles RBAC Spring Security ; l’existence de réponses 401/403 dans les Swagger suggère des contrôles en amont ou dans des couches non présentes dans ce dépôt",
      "note": "Analyse fondée sur le staging et les Swagger/clients générés disponibles : aucune configuration SecurityFilterChain/WebSecurityConfigurerAdapter n’a été détectée, ce qui indique une sécurité probablement externalisée plutôt qu’implémentée directement dans ce code."
    },
    "note": "Backend legacy packagé en WAR et déployé sur Tomcat. Expose une API REST via /api/*, des servlets legacy (/personne/*, /evenement/*, /codepromo/*, /demande/*, /parametrage/*, /opportunite/*, /asyncValue), ainsi que des flux JMS et Kafka.",
